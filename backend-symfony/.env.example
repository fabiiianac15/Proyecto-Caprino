# Configuración del entorno — COPIAR A .env.local Y AJUSTAR VALORES

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=cambiar_este_secreto_en_produccion_muy_largo_y_aleatorio
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Oracle Autonomous Database
# 1. Descarga el wallet desde Oracle Cloud Console:
#    ADB → DB Connection → Download Wallet
# 2. Extrae el ZIP en una carpeta local (ej: C:\Caprino-Wallet)
# 3. DATABASE_TNS_NAME: alias del tnsnames.ora del wallet
#    (normalmente: <nombre_db>_high, <nombre_db>_medium, <nombre_db>_low)
DATABASE_TNS_NAME=caprinodb_high
DATABASE_USER=caprino_user
DATABASE_PASSWORD=TuPasswordADB2025!
DATABASE_WALLET_PATH=C:\Caprino-Wallet
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
# HS256 — no se necesitan ficheros PEM. Cambiar este valor antes de producción.
JWT_SECRET=cambiar_este_secreto_jwt_muy_largo_y_aleatorio
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

APP_NAME="Sistema de Gestión Zootécnica Caprina"
APP_VERSION=1.0.0
APP_TIMEZONE=America/Bogota
