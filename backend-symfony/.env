# Configuración del entorno de desarrollo
# En producción, copiar valores sensibles a .env.local (no se sube a git)

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=cambiar_este_secreto_en_produccion
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Oracle Autonomous Database (nube)
# DATABASE_TNS_NAME: alias del tnsnames.ora del wallet (ej: caprinodb_high)
# DATABASE_WALLET_PATH: carpeta donde extrajiste el wallet ZIP
DATABASE_TNS_NAME=caprinodb_high
DATABASE_USER=caprino_user
DATABASE_PASSWORD=CaprinoPass2025
DATABASE_WALLET_PATH=C:\Caprino-Wallet
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
# HS256 — no se necesitan ficheros PEM. Cambiar este valor antes de producción.
JWT_SECRET=caprino_jwt_secret_2025_cambiar_en_produccion
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

APP_NAME="Sistema de Gestión Zootécnica Caprina"
APP_VERSION=1.0.0
APP_TIMEZONE=America/Bogota
