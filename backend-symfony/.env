# Configuración del entorno de desarrollo
# En producción, copiar a .env.local y configurar valores reales

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=cambiar_este_secreto_en_produccion
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# ── OPCIÓN A: Oracle XE local (activo por defecto) ──────────────────────────
DATABASE_HOST=127.0.0.1
DATABASE_PORT=1521
DATABASE_NAME=XEPDB1
DATABASE_USER=caprino_user
DATABASE_PASSWORD=CaprinoPass2025

# ── OPCIÓN B: Oracle Autonomous DB en la nube ────────────────────────────────
# Para activar el modo cloud, descomentar estas líneas y comentar la OPCIÓN A.
# Pasos previos:
#   1. Descargar wallet: Oracle Cloud Console → ADB → DB Connection → Download Wallet
#   2. Extraer el zip en: C:\Caprino-Wallet\
#   3. Editar C:\Caprino-Wallet\sqlnet.ora y asegurarse que diga:
#      WALLET_LOCATION = (SOURCE = (METHOD = file)(METHOD_DATA = (DIRECTORY="C:\Caprino-Wallet")))
#   4. DATABASE_TNS_NAME: es el alias del tnsnames.ora del wallet
#      (ej: caprinodb_high, caprinodb_medium o caprinodb_low)
#
#DATABASE_WALLET_PATH=C:\Caprino-Wallet
#DATABASE_TNS_NAME=caprinodb_high
#DATABASE_USER=caprino_user
#DATABASE_PASSWORD=TuPasswordADB2025!
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=cambiar_passphrase_en_produccion
JWT_TOKEN_TTL=28800
###< lexik/jwt-authentication-bundle ###

# Clave secreta para firmar los tokens JWT de la API (api.php)
# CAMBIAR este valor antes de ir a producción. Usar una cadena aleatoria larga.
JWT_SECRET=caprino_jwt_secret_2025_cambiar_en_produccion

###> nelmio/cors-bundle ###
# En producción, especificar dominios exactos
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

# Configuración de la aplicación
APP_NAME="Sistema de Gestión Zootécnica Caprina"
APP_VERSION=1.0.0
APP_TIMEZONE=America/Mexico_City

# Configuración de logs
LOG_LEVEL=debug
LOG_FILE_PATH=%kernel.logs_dir%/%kernel.environment%.log

# Configuración de caché (para producción usar Redis)
CACHE_DRIVER=filesystem

# Límite de registros por página en API
API_PAGINATION_ITEMS_PER_PAGE=30
API_PAGINATION_MAXIMUM_ITEMS_PER_PAGE=100
