# Configuración del entorno de desarrollo
# En producción, copiar a .env.local y configurar valores reales

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=cambiar_este_secreto_en_produccion
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Configuración para Oracle Database usando PDO_OCI
# Formato: //host:port/service_name o IP directa
# Oracle está en la máquina local (127.0.0.1)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=1521
DATABASE_NAME=XEPDB1
DATABASE_USER=caprino
DATABASE_PASSWORD=CaprinoPass2025
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=cambiar_passphrase_en_produccion
JWT_TOKEN_TTL=28800
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
# En producción, especificar dominios exactos
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

# Configuración de la aplicación
APP_NAME="Sistema de Gestión Zootécnica Caprina"
APP_VERSION=1.0.0
APP_TIMEZONE=America/Mexico_City

# Configuración de logs
LOG_LEVEL=debug
LOG_FILE_PATH=%kernel.logs_dir%/%kernel.environment%.log

# Configuración de caché (para producción usar Redis)
CACHE_DRIVER=filesystem

# Límite de registros por página en API
API_PAGINATION_ITEMS_PER_PAGE=30
API_PAGINATION_MAXIMUM_ITEMS_PER_PAGE=100
